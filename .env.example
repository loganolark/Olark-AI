# Aiden API (server-side only — never NEXT_PUBLIC_)
AIDEN_API_KEY=

# HubSpot Private App Token (server-side only — never NEXT_PUBLIC_)
HUBSPOT_API_KEY=

# Google Analytics 4 (safe to expose — client-side tracking)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Sentry (server-side DSN for API route error capture)
SENTRY_DSN=

# Sentry (client-side DSN for browser error capture)
NEXT_PUBLIC_SENTRY_DSN=
